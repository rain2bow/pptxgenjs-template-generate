{
  "name": "pptxgenjs-template-generate",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "sample": "node scripts/generate-pptx.js --sample --out outputs/sample-deck.pptx",
    "sample:swiss": "node scripts/generate-pptx.js --sample --sample-style swiss --out outputs/sample-deck.pptx",
    "sample:magazine": "node scripts/generate-pptx.js --sample --sample-style magazine --out outputs/sample-magazine.pptx",
    "sample:cmb": "node scripts/generate-pptx.js --sample --sample-style cmb --out outputs/sample-cmb.pptx",
    "sample:cmb:layouts": "node assets/template-cmb-all-layouts.js",
    "sample:cmb:max-text": "node assets/make-cmb-all-layouts-max-text.js",
    "validate:native": "node scripts/validate-pptx-native.js",
    "validate:layout": "node scripts/validate-pptx-layout.js",
    "spec:md": "node scripts/spec-to-md.js",
    "check:media-slots": "node scripts/check-media-slot-warnings.js",
    "capacity:cmb": "node scripts/generate-pptx.js --capacity-guide cmb --out outputs/cmb-capacity-guide.md",
    "capacity:swiss": "node scripts/generate-pptx.js --capacity-guide swiss --out outputs/swiss-capacity-guide.md",
    "capacity:magazine": "node scripts/generate-pptx.js --capacity-guide magazine --out outputs/magazine-capacity-guide.md",
    "docx:extract": "node scripts/docx-to-pptx.js"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide": "^0.525.0",
    "pptxgenjs": "^3.12.0",
    "sharp": "^0.33.5"
  }
}
